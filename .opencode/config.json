{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/qwen2.5-coder",
  "small_model": "ollama/llama3.1",
  "instructions": [
    "AGENTS.md"
  ],
  "provider": {
    "ollama": {
      "options": {
        "baseURL": "http://localhost:11434",
        "timeout": 600000
      }
    },
    "local-openai-compatible": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local OpenAI-Compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "timeout": 600000
      },
      "models": {
        "qwen2.5-coder": {
          "name": "Qwen 2.5 Coder"
        },
        "llama3.1": {
          "name": "Llama 3.1"
        }
      }
    }
  },
  "watcher": {
    "ignore": [
      ".git/**",
      "__pycache__/**",
      ".pytest_cache/**"
    ]
  }
}
